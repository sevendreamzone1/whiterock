{
  "name": "express-mysql-api",
  "version": "1.0.0",
  "description": "Express API connected to MySQL locally and PostgreSQL on Vercel.",
  "main": "dist/server.js",
  "scripts": {
    "build": "npm run build:api && npm run build:client",
    "build:api": "tsc",
    "build:client": "vite build --config client/vite.config.ts",
    "start": "node dist/server.js",
    "dev": "tsx watch src/server.ts",
    "dev:client": "vite --config client/vite.config.ts --host 127.0.0.1",
    "typecheck": "npm run typecheck:api && npm run typecheck:client",
    "typecheck:api": "tsc --noEmit",
    "typecheck:client": "tsc --project client/tsconfig.json --noEmit",
    "db:setup": "tsx src/scripts/setup-db.ts",
    "db:schema": "tsx src/scripts/run-schema.ts",
    "db:schema:mysql": "tsx src/scripts/run-schema.ts",
    "db:schema:postgres": "tsx src/scripts/run-postgres-schema.ts",
    "db:check": "tsx src/scripts/check-db.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@tailwindcss/vite": "^4.2.4",
    "@tanstack/react-query": "^5.100.9",
    "@tanstack/react-table": "^8.21.3",
    "bcryptjs": "^3.0.3",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^1.14.0",
    "mysql2": "^3.22.3",
    "pg": "^8.20.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-hook-form": "^7.75.0",
    "react-router-dom": "^7.15.0",
    "tailwindcss": "^4.2.4"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.6.0",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.10"
  }
}
